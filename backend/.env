# Database Configuration - Centralized Secrets
# Note: Update these values in production.
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexusdiet

# Application Configuration
# We construct the URL dynamically using the variables above. 
# This ensures you only have to update your password in one place!
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
