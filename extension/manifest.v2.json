{
  "manifest_version": 2,
  "name": "Nexus Diet - Information Dashboard",
  "version": "1.0",
  "description": "Track your information diet based on what you browse.",
  "permissions": [
    "activeTab",
    "storage",
    "http://*/*",
    "https://*/*",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nexusdiet@r3gal08.com",
      "strict_min_version": "109.0"
    }
  },
  "browser_action": {
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
