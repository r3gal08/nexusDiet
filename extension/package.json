  },
  "homepage": "https://github.com/r3gal08/nexusDiet#readme",
  "devDependencies": {
    "copy-webpack-plugin": "^13.0.1",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.0.0"
  }
