{
  "name": "nexusdiet",
  "version": "1.0.0",
  "description": "",
  "main": "Readability.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:dashboard": "cd ../dashboard && npm install && npm run build",
    "build": "npm run build:dashboard && webpack --env MANIFEST_VER=3",
    "build:v2": "npm run build:dashboard && webpack --env MANIFEST_VER=2",
    "build:v3": "npm run build:dashboard && webpack --env MANIFEST_VER=3",
    "zip:v2": "npm run build:v2 && mkdir -p dist && cd dist && zip -r ../nexusDiet_v2.zip . && cd ..",
    "zip:v3": "npm run build:v3 && mkdir -p dist && cd dist && zip -r ../nexusDiet_v3.zip . && cd ..",
    "watch": "webpack --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r3gal08/nexusDiet.git"
  },
  "keywords": [],
